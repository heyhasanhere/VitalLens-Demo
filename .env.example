# ── Model paths ───────────────────────────────────────────────────────────────
# Paths are relative to the repo root, or use absolute paths.
# Swap RPPG_MODEL_PATH to switch between the two bundled models:
#   FactorizePhys (default, better accuracy):  weights/factorizephys.onnx
#   VitalLens EfficientPhys:                   weights/vitallens_rppg.onnx
RPPG_MODEL_PATH=weights/factorizephys.onnx
LIGHTING_MODEL_PATH=weights/vitallens_lighting.onnx
FACE_LANDMARKER_PATH=weights/face_landmarker.task

# ── Camera ────────────────────────────────────────────────────────────────────
# Index of the default capture device. Call GET /cameras to discover indices.
CAMERA_INDEX=0
# Set to 1 to force the V4L2 backend on Linux (required for some USB cameras).
USE_V4L2=0
CAMERA_OPEN_RETRIES=5
CAMERA_OPEN_RETRY_DELAY=1.0

# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated allowed origins, or * to allow all.
CORS_ORIGINS=*

# ── Optional integrations ─────────────────────────────────────────────────────
# Enables age-based HR zone display in the frontend (see README).
# OPENAI_API_KEY=sk-...
