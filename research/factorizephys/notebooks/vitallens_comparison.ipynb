    clips = torch.load(str(cache_path), weights_only=False)
    print(f"  Clips loaded: {len(clips)}")

    # --- Our model ---
    t1 = time.time()
    our_p, our_g, our_s = eval_cache_ours(our_model, clips, device, gt_mode)
    our_mae, our_rmse, our_r = compute_metrics(our_p, our_g)
    print(f"  Our model  : {len(our_s)} subj | MAE={our_mae:.3f} | RMSE={our_rmse:.3f} | r={our_r:.4f} | {time.time()-t1:.1f}s")

    # --- VitalLens ---
    t2 = time.time()
    vl_p, vl_g, vl_s = eval_cache_vitallens(vl_sess, vl_inp_name, clips)
    vl_mae, vl_rmse, vl_r = compute_metrics(vl_p, vl_g)
    print(f"  VitalLens : {len(vl_s)} subj | MAE={vl_mae:.3f} | RMSE={vl_rmse:.3f} | r={vl_r:.4f} | {time.time()-t2:.1f}s")

    results[name] = {
        'n_subjects': (len(our_s), len(vl_s)),
        'our':        {'MAE': our_mae, 'RMSE': our_rmse, 'r': our_r, 'preds': our_p, 'gts': our_g, 'subjs': our_s},
        'vitallens':  {'MAE': vl_mae, 'RMSE': vl_rmse, 'r': vl_r, 'preds': vl_p, 'gts': vl_g, 'subjs': vl_s},
