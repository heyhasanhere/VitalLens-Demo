# ── Step 2: Signal processing ────────────────────────────────────────────────

def extract_hr_fft(waveform, fps=FPS, lo=FFT_LO, hi=FFT_HI):
    """FFT bandpass peak HR — identical to our eval notebook."""
    freqs = np.fft.rfftfreq(len(waveform), d=1.0/fps)
    fft   = np.abs(np.fft.rfft(waveform.astype('float64')))
    mask  = (freqs >= lo) & (freqs <= hi)
    if not mask.any(): return float('nan')
    return float(freqs[mask][np.argmax(fft[mask])] * 60.0)


def vitallens_hr(bvp, fps=FPS):
    """VitalLens-style HR extraction: Welch PSD with parabolic interp."""
    if len(bvp) < 64: return float('nan')
    nyq = fps / 2.0
    lo, hi = max(0.67/nyq, 1e-4), min(3.0/nyq, 0.9999)
    try:
        b, a = butter(3, [lo, hi], btype='band')
        bvp_f = filtfilt(b, a, bvp)
    except Exception:
        bvp_f = bvp
    freqs, psd = welch(bvp_f, fs=fps, nperseg=min(len(bvp_f), 150), nfft=2048)
    band = (freqs >= 0.67) & (freqs <= 3.0)
    if not band.any(): return float('nan')
    band_psd  = psd[band]
    band_freq = freqs[band]
    k = band_psd.argmax()
    if 0 < k < len(band_psd) - 1:
        a_v, b_v, g = band_psd[k-1], band_psd[k], band_psd[k+1]
        denom = a_v - 2*b_v + g
        if abs(denom) > 1e-10:
            df = freqs[1] - freqs[0] if len(freqs) > 1 else 0.0
            return float((band_freq[k] + 0.5*(a_v-g)/denom*df) * 60.0)
    return float(band_freq[k] * 60.0)


def build_vitallens_input(frames):
    """
    Build VitalLens DiffNorm input from [3, 161, H, W] float32 tensor.
    frames: torch tensor in [0, 1] range
    Returns: [1, 160, 3, 128, 128] numpy float32
    """
    # frames: (3, 161, H, W) — contiguous
    arr = frames.permute(1, 0, 2, 3).numpy()   # (161, 3, H, W)
    # Resize each frame to 128x128 using bilinear interpolation
    resized = np.stack([
        np.transpose(
            np.clip(
                torch.nn.functional.interpolate(
                    torch.from_numpy(arr[t:t+1].transpose(0,3,1,2)),  # (1, 3, H, W)
                    size=(VITALLENS_SIZE, VITALLENS_SIZE),
                    mode='bilinear',
                    align_corners=False,
                    antialias=True,
                ).numpy()[0],
            0, 3, 1, 2  # back to (3, 128, 128)
            ),
        0, 3, 1, 2)
        for t in range(len(arr))
    ], axis=0)   # (161, 3, 128, 128)

    # Brightness normalise per frame
    lum = resized.mean(axis=(1,2,3), keepdims=True) + 1e-6
    resized = resized / lum

    # Temporal difference
    f_next = resized[1:]
    f_curr = resized[:-1]
    diff = (f_next - f_curr) / (f_next + f_curr + 1e-6)
    diff = np.clip(diff, -3.0, 3.0)
    diff = diff.transpose(0, 3, 1, 2)    # (160, 3, 128, 128)
    return diff[np.newaxis].astype('float32')   # (1, 160, 3, 128, 128)


# ── Step 3: Unified inference and evaluation ─────────────────────────────────

def eval_cache_ours(model, clips, device, gt_mode='fft'):
    """Evaluate our model on pre-built eval cache. Returns (preds, gts, subjs)."""
    model.eval()
    subj_preds = defaultdict(list)
    subj_gt = {}
    batch_size = 8

    for i in range(0, len(clips), batch_size):
        batch = clips[i:i+batch_size]
        frames = torch.stack([c['frames'] for c in batch]).to(device)
        with torch.no_grad():
            out = model(frames)
            preds = out[0].float().cpu().numpy()   # (B, T)

        for j, clip in enumerate(batch):
            hr = extract_hr_fft(preds[j])
            if not (HR_LO <= hr <= HR_HI): continue
            subj = clip['subj']
            subj_preds[subj].append(hr)
            if subj not in subj_gt:
                if gt_mode == 'fft':
                    subj_gt[subj] = extract_hr_fft(clip['ppg'].numpy())
                else:
                    subj_gt[subj] = float(clip['gt_hr'])

    return _aggregate(subj_preds, subj_gt)


def eval_cache_vitallens(sess, inp_name, clips):
    """Evaluate VitalLens ONNX on pre-built eval cache. Returns (preds, gts, subjs)."""
    subj_preds = defaultdict(list)
    subj_gt = {}

    for clip in clips:
        frames = clip['frames']   # (3, 161, 72, 72)
        vl_in  = build_vitallens_input(frames)
        bvp    = sess.run(None, {inp_name: vl_in})[0][0]   # (160,)
        hr     = vitallens_hr(bvp)
        if not (HR_LO <= hr <= HR_HI): continue
        subj = clip['subj']
        subj_preds[subj].append(hr)
        if subj not in subj_gt:
            if 'ppg' in clip:
                subj_gt[subj] = extract_hr_fft(clip['ppg'].numpy())
            else:
                subj_gt[subj] = float(clip['gt_hr'])

    return _aggregate(subj_preds, subj_gt)


def _aggregate(subj_preds, subj_gt):
    preds_list, gts_list, subjs = [], [], []
    for subj, preds in subj_preds.items():
        if len(preds) < MIN_CLIPS: continue
        gt = subj_gt.get(subj)
        if gt is None or math.isnan(gt): continue
        pm = float(np.mean(preds))
        if not (HR_LO <= pm <= HR_HI): continue
        preds_list.append(pm)
        gts_list.append(gt)
        subjs.append(subj)
    return preds_list, gts_list, subjs


def compute_metrics(preds, gts):
    err = np.array(preds) - np.array(gts)
    mae  = float(np.abs(err).mean())
    rmse = float(np.sqrt((err**2).mean()))
    r    = float(np.corrcoef(preds, gts)[0,1]) if len(preds)>1 else float('nan')
    return mae, rmse, r


